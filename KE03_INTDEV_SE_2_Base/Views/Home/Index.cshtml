@using DataAccessLayer.Models
@model IEnumerable<DataAccessLayer.Models.Part>


<h2>Onderdelenlijst</h2>

<table class="table">
    <thead>
        <tr>
            <th>Naam</th>
            <th>Beschrijving</th>
            <th>Aantal gekoppelde producten</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
		@foreach (var part in Model)
        {
            <tr>
				<td>>@part.Id</td>
                <td>@part.Name</td>
                <td>@part.Description</td>
                <td>@(part.Products != null ? part.Products.Count : 0)</td>

                
                <td>
                    <a asp-action="Details" asp-route-id="@part.Id" class="btn btn-info btn-sm">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>




<div style="height:20px; width:20px;">
    <button type="button">Test</button>
</div>